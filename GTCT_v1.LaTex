\midrule
$0.20 \;(<1/3)$  & $-2+0.6 = -1.4$ & $e^{-1.4} \approx 0.247$ & Yes & Stable \\
$0.333\;(=1/3)$  & $-2+1.0 = -1.0$ & $e^{-1.0} \approx 0.368$ & Yes & Marginal \\
$0.40 \;(>1/3)$  & $-2+1.2 = -0.8$ & $e^{-0.8} \approx 0.449$ & No  & Slower decay \\
$0.80 \;(>1/3)$  & $-2+2.4 = +0.4$ & $e^{+0.4} \approx 1.492$ & No  & GROWING \\
\bottomrule
\end{tabular}
\end{center}
