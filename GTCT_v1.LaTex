\section{The $g$-Series: A Regime Taxonomy}

The $\mathrm{dm}^3$-GTCT framework uses a taxonomy of behavioral scales called the
$g$-series. This section defines the taxonomy precisely. The $g$-series makes no
mathematical claims about the index values; the indices are labels chosen by the
criteria stated below, not derived constants.

\begin{definition}[$g$-Series Taxonomy]
The $g$-series is a finite ordered set of regime labels:
\[
g^0 < g^2 < g^6 < g^{33} < g^{64}.
\]
Each label $g^k$ names a qualitative behavioral regime of a $\mathrm{dm}^3$ system.
The superscript $k$ is an ordinal index, not an exponent. The series is not a sequence
of numbers; it is a classification.
\end{definition}

\begin{definition}[Index Criteria]
The five indices are assigned by the following criteria, each corresponding to a
qualitatively distinct stability property of the operator chain $G = U \circ F \circ
K \circ C$:

\bigskip
\begin{tabular}{@{}P{1.2cm}P{1cm}P{2.8cm}P{7.5cm}@{}}
\toprule
\textbf{Label} & \textbf{Index} & \textbf{Regime} & \textbf{Criterion} \\
\midrule
$g^0$  & 0  & Seed & Single operator application; no closure condition. \\[3pt]
$g^2$  & 2  & Compositional & Two-operator closure; minimal self-reference ($F$ active). \\[3pt]
$g^6$  & 6  & Cycle-scale & Full $G$-cycle closure; limit cycle $\Gamma$ entered. \\[3pt]
$g^{33}$ & 33 & Soft equilibrium & Heuristic stability index: $\lceil\log_2(3!)\cdot 4\rceil \times 3 = 33$.
  See Remark~\ref{rem:33}. \\[3pt]
$g^{64}$ & 64 & Phase threshold & Complete possibility-space coverage; $2^6 = 64$ operator-state combinations. \\
\bottomrule
\end{tabular}
\end{definition}

\begin{remark}[Status of the index 33]\label{rem:33}
The index 33 arises from the following heuristic computation: there are three
invariants that must close simultaneously (orthogonality, nilpotency of deviations,
spectral collapse), giving $3! = 6$ orderings; $\log_2(6) \times 4 \approx 10.34$,
so $\lceil\log_2(3!) \times 4\rceil = 11$; multiplying by 3 for a
triple-confirmation robustness criterion gives $3 \times 11 = 33$. This computation
is heuristic. The ``multiply by~3'' step reflects a design choice --- that three
independent closures are required for robust stability --- which is \emph{not} derived
from the contact-geometric structure of Sections~5--6. The index~33 is therefore a
motivated label, not a theorem. Its mathematical status is that of a conjecture: we
conjecture that $\mathrm{dm}^3$ systems require at least 33 operator cycles for the
three invariants to achieve simultaneous robust closure, and we identify this as an
open verification target for the AXLE Lean~4 repository.
\end{remark}

\begin{remark}[Crystal notation]
The notation $g^6\!:\!33$ and $g^{33}\!:\!33$ used elsewhere in the Principia
Orthogona series denotes association, not equality. `$g^6\!:\!33$' means: the
cycle-scale regime $g^6$ carries the structural index~33. It is a descriptor of the
same kind as `$D_6$ symmetry: 6-fold' or `$E_8$ lattice: rank~8'. No algebraic
identity $g^6 = 33$ is claimed.
\end{remark}

\section{Definitions and Axioms}

\begin{definition}[Generative Operator Chain]
The single-cycle generative operator is $G = U \circ F \circ K \circ C$, where:
\begin{itemize}[leftmargin=*]
  \item $C$ \emph{(Compression)}: reduces complexity to a minimal viable seed;
    injective and contractive.
  \item $K$ \emph{(Constraint)}: defines the curvature boundaries that make form
    possible; decreases potential $\Phi$.
  \item $F$ \emph{(Fold)}: creates the first self-reference, curving the system back
    onto itself; non-injective with finite branch set.
  \item $U$ \emph{(Unfolding)}: releases latent potential into visible reality;
    decreases $\Phi$ and drives orbits toward a fixed point.
\end{itemize}
One complete application of $G$ is one generative cycle. The full chain including
the fifth operator is: $C \to K \to F \to U \to T \to \mathrm{source}$.
\end{definition}

\begin{definition}[Stability Threshold $g^{33} = 33$]
The index 33 is the heuristic stability threshold for regenerative coherence ---
simultaneous closure of the three invariants (orthogonality, nilpotency of
deviations, spectral collapse). The computation is:
\[
n_{\min} = \left\lceil \log_2(3!) \cdot 4 \right\rceil
         = \left\lceil \log_2(6) \cdot 4 \right\rceil
         = \lceil 10.3398\ldots \rceil = 11,
\qquad
g^{33} = 3 \times n_{\min} = 33.
\]
This derivation is combinatorial and heuristic; see Remark~\ref{rem:33} for the
precise mathematical status. Below 33 cycles the system is conjectured to be fragile.
At or above 33, the organizing invariant is conjectured to persist across disruption.
\end{definition}

\begin{definition}[Circuit Saturation at $g^{64}$]
After 64 cycles the system maps its entire possibility space (Complete Completeness):
$x_{64} := G^{64}(x_0)$.
\end{definition}

\begin{definition}[The Spiral Return]
The return is a new application of $G$ at circuit scale on the contact manifold:
\[
x_0 \xrightarrow{G^{64}} x_{64} \xrightarrow{G^{64}} x_0', \quad x_0' \neq x_0.
\]
This is a spiral, not a loop. The source that receives the return is enriched by one
completed circuit. The action variable $z$ accumulates dissipation along the return:
$dz/dt = f(x) \geq 0$ on $\Gamma$, encoding the thermodynamic cost of the full
circuit in the contact form $\alpha = dz - \lambda$.
\end{definition}

\section{Theorem T1 --- The Generative Time Circuit}

\begin{theorem}[Generative Time Circuit Theorem --- GTCT]\label{thm:gtct}
In the TOGT operator algebra on the contact manifold $M = S \times \mathbb{R}$ with
contact form $\alpha = dz - \lambda$, time is the generative circuit operator $T$:
the fifth stage of the operator chain $C \to K \to F \to U \to T$. For any
$\mathrm{dm}^3$ system $D = (S, g, Y, \Gamma, V, \sigma)$ that has completed at
least $g^{33} = 33$ generative cycles, the spiral return
$x_0' = G^{64}(G^{64}(x_0))$ satisfies $x_0' \neq x_0$. The action variable $z$
increases monotonically along the return, encoding the thermodynamic cost of the
completed circuit. Structural stability holds within the $\mathrm{dm}^3$ radius
$\varepsilon_0 = 1/3$ (Theorem~D, Volume~II~\cite{grossi2026}).
\end{theorem}

\section{Complete Proof}

The proof proceeds in five steps using only the operator algebra and the
$\mathrm{dm}^3$ contact-geometric structure established in Volumes~I and~II.

\medskip
\noindent\textbf{Step 1. Circuit geometry --- not a line.}
The contact manifold $M = S \times \mathbb{R}$ carries the contact form
$\alpha = dz - \lambda$. Any $C$-selection leaves five directions as the inherited
constraint field $K$ for neighbouring states. Space is a record of operator
interactions. The operator chain is explicitly a circuit:
$C \to K \to F \to U \to T \to \mathrm{source}$.
Therefore, time $T$ is the full circuit operator, not a linear parameter.
\hfill\emph{(QED Step~1)}

\medskip
\noindent\textbf{Step 2. Stability via the $g^{33}$ conjecture (the Cajueiro Principle).}
By Definition~3.2, the heuristic stability index~33 is the conjectured minimum number
of cycles for the three invariants to achieve simultaneous, robust closure. The
$\mathrm{dm}^3$ Lyapunov function $V(\rho) = \tfrac{1}{2}(\rho-1)^2$ guarantees that
for any perturbation $\|Y\| \leq \varepsilon < \varepsilon_0 = 1/3$, the transverse
deviation $\xi(t) = \rho(t) - 1$ satisfies the Gronwall bound (Theorem~D,
Volume~II~\cite{grossi2026}):
\[
|\xi(t)| \leq |\xi(0)| \cdot \exp\!\bigl((|\mu_{\max}| + 3\varepsilon)\,t\bigr)
\to 0 \quad \text{when } \varepsilon < 1/3.
\]
The system is self-sustaining and regenerates after any disruption within
$\varepsilon_0$.
\hfill\emph{(QED Step~2)}

\medskip
\noindent\textbf{Step 3. Saturation at $g^{64}$.}
In the $\mathrm{dm}^3$ contact system on $M = S^1 \times \mathbb{R}$, the flow of
$G$ over $T^* = 2\pi$ is governed by the contact normal form (Theorem~C,
Volume~II~\cite{grossi2026}):
\[
\frac{d\rho}{dt} = \mu_{\max}(1 - e^{-\beta z})\rho, \quad
\frac{d\theta}{dt} = \omega, \quad
\frac{dz}{dt} = \omega - |\mu_{\max}|\rho^2 e^{-\beta z}.
\]
The transverse multiplier is
$\lambda_\perp = \exp(\mu_{\max} T^*) = \exp(-4\pi) \approx 3.49 \times 10^{-6}$
in the canonical toy model ($\mu_{\max} = -2$, $T^* = 2\pi$). After 64 applications
the full possibility space is mapped: $x_{64} := G^{64}(x_0)$.
\hfill\emph{(QED Step~3)}

\medskip
\noindent\textbf{Step 4. Spiral Return.}
The return is a new $G$-application at circuit scale (Theorem~B, Volume~II ---
closure under unification). In contact coordinates, the return accumulates
dissipation in the action variable $z$:
\[
x_0 \xrightarrow{G^{64}} x_{64} \xrightarrow{G^{64}} x_0', \quad x_0' \neq x_0.
\]
The Fold operator $F$ curves the trajectory back onto itself (first self-reference).
The action variable $z$ satisfies $dz/dt \geq 0$ along $\Gamma$, so the source
state $x_0'$ carries a strictly greater accumulated entropy than $x_0$. Macroscopic
linear history remains irreversible (entropy and decoherence above the manifold); at
the generative level the source is enriched --- not rewritten --- by one completed
circuit.
\hfill\emph{(QED Step~4)}

\medskip
\noindent\textbf{Step 5. Structural stability of the return.}
By Theorem~D (Volume~II~\cite{grossi2026}), all operators preserve the
$\mathrm{dm}^3$ structure within the stability radius:
\[
\varepsilon_0
= \frac{|\mu_{\max}|}{2(1 + \sup_\Gamma \|\mathrm{Hess}\,V\|)}
= \frac{2}{2(1+2)} = \frac{1}{3}.
\]
Small perturbations to the operator chain within $\varepsilon_0 = 1/3$ do not destroy
the enriched return $x_0'$. The spiral return is a generic property of any
$\mathrm{dm}^3$ system operating above the $g^{33}$ stability index, not an artifact
of fine-tuned parameters.
\hfill\emph{(QED Step~5)}

\medskip
\noindent\textbf{Conclusion.} Once the $g^{33}$ stability index is reached and the
full circuit closes at $g^{64}$, the action variable $z$ accumulates strictly
positive dissipation over every complete circuit. The source state is therefore
enriched --- carrying the accumulated thermodynamic cost of one full circuit ---
rather than returned to its original configuration. This is the spiral return.
Structural stability holds within $\varepsilon_0 = 1/3$.
\hfill\emph{(QED Theorem~\ref{thm:gtct})}

\section{The Gronwall Inequality and $\varepsilon_0 = 1/3$}

\begin{theorem}[Gronwall Inequality --- Differential Form]
Let $u(t) \geq 0$ satisfy $u'(t) \leq k(t)u(t) + f(t)$, $u(0) = a \geq 0$,
with $k, f$ continuous. Then:
\[
u(t) \leq a\,e^{\int_0^t k(s)\,ds}
+ \int_0^t f(s)\,e^{\int_s^t k(r)\,dr}\,ds.
\]
\end{theorem}

\begin{proof}[Proof sketch]
Define $\mu(t) = \exp(-\int_0^t k\,ds)$. Then
$\tfrac{d}{dt}[u \cdot \mu] \leq f \cdot \mu$. Integrate and divide by $\mu(t)$.
\end{proof}

\noindent\textbf{Application to the $\mathrm{dm}^3$ Transverse Deviation.}
The transverse deviation $\xi(t) = \rho(t) - 1$ from $\Gamma = \{\rho = 1\}$ under
perturbation $\|Y\| \leq \varepsilon$ satisfies:
\[
\left|\frac{d\xi}{dt}\right|
\leq |\mu_{\max}||\xi(t)| + \varepsilon(1 + \sup_\Gamma\|\mathrm{Hess}\,V\|)|\xi(t)|.
\]
By Gronwall with $k = |\mu_{\max}| = 2$ and $\sup\|\mathrm{Hess}\,V\| = 2$:
\[
\varepsilon_0 = \frac{2}{2(1+2)} = \frac{1}{3} \quad \text{(exact).}
\]

\bigskip
\begin{center}
