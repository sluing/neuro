\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Pre-saturation spreading rates $\alpha $ fitted from $\mathrm  {IPR}(t) \sim t^{-\alpha }$ in the window $t > 10^4$ at $T=10^5$, $N=2000$. Standard errors and $R^2$ from OLS on $\qopname  \relax o{log}_{10}$IPR vs $\qopname  \relax o{log}_{10}t$.\relax }}{9}{table.caption.14}\protected@file@percent }
\newlabel{tab:alpha}{{2}{9}{Pre-saturation spreading rates $\alpha $ fitted from $\mathrm {IPR}(t) \sim t^{-\alpha }$ in the window $t > 10^4$ at $T=10^5$, $N=2000$. Standard errors and $R^2$ from OLS on $\log _{10}$IPR vs $\log _{10}t$.\relax }{table.caption.14}{}}
\citation{Lahini2009}
\citation{Krebbekx2023}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Finite-size scaling of the differential ratio $\mathrm  {IPR}_{\rm  trib}/\mathrm  {IPR}_{\rm  fib}$ at $T=10^4$, across $N \in \{500, 1000, 2000\}$ and $\lambda \in \{0.5, 1.0, 1.5, 2.0, 3.0, 4.0, 5.0\}$. The ratio is greater than unity at every $(\lambda ,N)$ pair, indicating tribonacci is more retained throughout. The differential generally grows with $N$ at fixed $\lambda $ (e.g.\ at $\lambda =1.0$ the ratio increases from $1.6\times $ at $N=500$ to $6.3\times $ at $N=2000$). The $\lambda =1.5$ row exhibits a non-monotone $N$-dependence with a peak at $N=1000$; the $T=10^5$ verification run (Section\nobreakspace  {}4.5) shows this peak is a transient feature.\relax }}{10}{figure.caption.11}\protected@file@percent }
\newlabel{fig:fss}{{7}{10}{Finite-size scaling of the differential ratio $\mathrm {IPR}_{\rm trib}/\mathrm {IPR}_{\rm fib}$ at $T=10^4$, across $N \in \{500, 1000, 2000\}$ and $\lambda \in \{0.5, 1.0, 1.5, 2.0, 3.0, 4.0, 5.0\}$. The ratio is greater than unity at every $(\lambda ,N)$ pair, indicating tribonacci is more retained throughout. The differential generally grows with $N$ at fixed $\lambda $ (e.g.\ at $\lambda =1.0$ the ratio increases from $1.6\times $ at $N=500$ to $6.3\times $ at $N=2000$). The $\lambda =1.5$ row exhibits a non-monotone $N$-dependence with a peak at $N=1000$; the $T=10^5$ verification run (Section~4.5) shows this peak is a transient feature.\relax }{figure.caption.11}{}}
